# Copy to `.env` and fill in. `.env` is gitignored — keep it that way.

OPENAI_API_KEY=sk-...

# Optional. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini

# Optional sampling temperature, 0.0–2.0. Unset means the API default (1.0).
# Lower is more deterministic, which tends to mean fewer pacing-rule violations
# and so fewer billed repair calls. Use the Cost Lab tab to find a good value.
# OPENAI_TEMPERATURE=0.3

# Optional cap on output tokens per call, sent as `max_completion_tokens`.
# Unset means no cap (the model's own ceiling applies).
#
# WARNING: this is a spend circuit-breaker, not a "make it shorter" knob. If a
# response is cut off mid-JSON the itinerary cannot be parsed, and you are still
# billed for every token generated. Set it comfortably above what a full trip
# needs — the Cost Lab shows where truncation starts.
# OPENAI_MAX_OUTPUT_TOKENS=8000

# Optional. Signs the session cookie for the HTML frontend (run_web.py). A dev
# default is used if unset — set a real random value for anything shared.
# WEB_SECRET_KEY=change-me-to-a-long-random-string
